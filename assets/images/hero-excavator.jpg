<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background Gradient -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#004E89;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1A1A2E;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="800" height="600" fill="url(#bgGradient)"/>
  
  <!-- Water -->
  <rect x="0" y="400" width="800" height="200" fill="#0FA3B1" opacity="0.8"/>
  <path d="M0 400 Q 100 390 200 400 T 400 400 T 600 400 T 800 400" fill="#0FA3B1" opacity="0.6"/>
  
  <!-- Pontoon Platform -->
  <rect x="100" y="350" width="600" height="60" fill="#8B7355" rx="8"/>
  <rect x="100" y="350" width="600" height="15" fill="#A0826D" rx="8"/>
  
  <!-- Chain Links on sides -->
  <g stroke="#FFD700" stroke-width="4" fill="none">
    <line x1="120" y1="350" x2="120" y2="300"/>
    <circle cx="120" cy="280" r="12"/>
    <circle cx="120" cy="260" r="12"/>
    <circle cx="120" cy="240" r="12"/>
    
    <line x1="680" y1="350" x2="680" y2="300"/>
    <circle cx="680" cy="280" r="12"/>
    <circle cx="680" cy="260" r="12"/>
    <circle cx="680" cy="240" r="12"/>
  </g>
  
  <!-- Excavator Body -->
  <g>
    <!-- Base -->
    <rect x="300" y="280" width="200" height="80" fill="#FF6B35" rx="4"/>
    <rect x="300" y="280" width="200" height="20" fill="#E85A2A" rx="4"/>
    
    <!-- Cabin -->
    <rect x="330" y="240" width="80" height="50" fill="#FF6B35" rx="4"/>
    <rect x="340" y="245" width="20" height="20" fill="#87CEEB"/>
    <rect x="365" y="245" width="20" height="20" fill="#87CEEB"/>
    
    <!-- Boom (Arm) -->
    <g stroke="#FF6B35" stroke-width="12" fill="none" stroke-linecap="round">
      <line x1="420" y1="240" x2="520" y2="140"/>
      <line x1="520" y1="140" x2="580" y2="110"/>
    </g>
    
    <!-- Bucket -->
    <g fill="#8B7355" stroke="#654321" stroke-width="2">
      <polygon points="580,110 620,110 610,150 570,150"/>
      <path d="M570 150 Q575 160 610 160 Q605 150 570 150"/>
    </g>
  </g>
  
  <!-- Clouds -->
  <g fill="white" opacity="0.7">
    <ellipse cx="100" cy="80" rx="50" ry="30"/>
    <ellipse cx="140" cy="85" rx="60" ry="35"/>
    <ellipse cx="60" cy="85" rx="45" ry="28"/>
    
    <ellipse cx="650" cy="120" rx="55" ry="32"/>
    <ellipse cx="695" cy="125" rx="65" ry="36"/>
    <ellipse cx="605" cy="125" rx="50" ry="30"/>
  </g>
  
  <!-- Title -->
  <text x="400" y="550" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">Excavator Amphibi Kami</text>
</svg>
