<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="workshop-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F7FAFC;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E2E8F0;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="800" height="600" fill="url(#workshop-bg)"/>
  
  <!-- Building -->
  <rect x="50" y="150" width="700" height="350" fill="#8B7355" stroke="#654321" stroke-width="3"/>
  <rect x="50" y="150" width="700" height="50" fill="#A0826D" stroke="#654321" stroke-width="2"/>
  
  <!-- Roof -->
  <polygon points="50,150 400,50 750,150" fill="#654321" stroke="#3D2817" stroke-width="2"/>
  
  <!-- Windows -->
  <g fill="#87CEEB" stroke="#333" stroke-width="2">
    <rect x="120" y="200" width="60" height="50"/>
    <rect x="220" y="200" width="60" height="50"/>
    <rect x="320" y="200" width="60" height="50"/>
    <rect x="420" y="200" width="60" height="50"/>
    <rect x="520" y="200" width="60" height="50"/>
    <rect x="620" y="200" width="60" height="50"/>
  </g>
  
  <!-- Doors -->
  <rect x="100" y="400" width="80" height="100" fill="#654321" stroke="#3D2817" stroke-width="2"/>
  <rect x="620" y="400" width="80" height="100" fill="#654321" stroke="#3D2817" stroke-width="2"/>
  
  <!-- Door handles -->
  <circle cx="175" cy="450" r="4" fill="#FFD700"/>
  <circle cx="695" cy="450" r="4" fill="#FFD700"/>
  
  <!-- Equipment outside -->
  <g fill="#FF6B35">
    <rect x="280" y="480" width="80" height="50" rx="4"/>
    <circle cx="300" cy="530" r="15" fill="#333"/>
    <circle cx="345" cy="530" r="15" fill="#333"/>
  </g>
  
  <!-- Chains/equipment on display -->
  <g stroke="#FFD700" stroke-width="4" fill="none" opacity="0.8">
    <line x1="450" y1="450" x2="450" y2="520"/>
    <circle cx="450" cy="530" r="8"/>
    <circle cx="450" cy="545" r="8"/>
  </g>
  
  <!-- Title -->
  <text x="400" y="570" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#004E89" text-anchor="middle">Workshop Modern - Surabaya</text>
</svg>
