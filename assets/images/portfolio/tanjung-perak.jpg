<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="sea" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0FA3B1;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#004E89;stop-opacity:1"/>
    </linearGradient>
  </defs>
  
  <!-- Sea background -->
  <rect width="800" height="600" fill="url(#sea)"/>
  
  <!-- Floating dock platform -->
  <rect x="150" y="250" width="500" height="80" fill="#8B7355" rx="6"/>
  <rect x="150" y="250" width="500" height="20" fill="#A0826D" rx="6"/>
  
  <!-- Support posts -->
  <rect x="200" y="330" width="20" height="120" fill="#654321"/>
  <rect x="380" y="330" width="20" height="120" fill="#654321"/>
  <rect x="580" y="330" width="20" height="120" fill="#654321"/>
  
  <!-- Chains anchoring -->
  <g stroke="#FFD700" stroke-width="4" fill="none">
    <line x1="180" y1="250" x2="120" y2="150"/>
    <line x1="670" y1="250" x2="730" y2="150"/>
    <circle cx="120" cy="130" r="10"/>
    <circle cx="730" cy="130" r="10"/>
  </g>
  
  <!-- Boat tied to dock -->
  <g fill="#FFFFFF">
    <ellipse cx="400" cy="320" rx="80" ry="30" fill="#E8E8E8"/>
    <rect x="350" y="290" width="100" height="30" rx="15" fill="#FFFFFF"/>
  </g>
  
  <!-- Bollards on dock -->
  <g fill="#333">
    <rect x="230" y="260" width="20" height="30" rx="4"/>
    <rect x="390" y="260" width="20" height="30" rx="4"/>
    <rect x="550" y="260" width="20" height="30" rx="4"/>
  </g>
  
  <!-- Water waves -->
  <path d="M0 380 Q100 370 200 380 T400 380 T600 380 T800 380" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
  <path d="M0 420 Q100 410 200 420 T400 420 T600 420 T800 420" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
  
  <!-- Harbor buildings in background -->
  <g fill="#1A1A2E" opacity="0.4">
    <rect x="50" y="150" width="60" height="80"/>
    <rect x="120" y="180" width="50" height="50"/>
    <rect x="680" y="160" width="70" height="70"/>
  </g>
  
  <!-- Title overlay -->
  <rect x="50" y="520" width="500" height="60" fill="rgba(0,0,0,0.7)" rx="8"/>
  <text x="70" y="545" font-family="Arial" font-size="20" fill="#F7B801" font-weight="bold">Dermaga Apung Pelabuhan Tanjung Perak</text>
  <text x="70" y="565" font-family="Arial" font-size="14" fill="white">Surabaya, Jawa Timur • 2023</text>
</svg>
