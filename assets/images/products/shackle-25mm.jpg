<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <defs><linearGradient id="g8" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#E2E8F0"/><stop offset="100%" style="stop-color:#CBD5E0"/></linearGradient></defs>
  <rect width="400" height="300" fill="url(#g8)"/>
  
  <!-- Shackle showing D-shape connector -->
  <g fill="none" stroke="#A0A0A0" stroke-width="8" stroke-linecap="round">
    <!-- Top D-shaped loop -->
    <path d="M 150 80 A 30 30 0 0 1 150 140"/>
    <line x1="150" y1="140" x2="150" y2="160"/>
    
    <!-- Bottom D-shaped loop -->
    <path d="M 250 160 A 30 30 0 0 1 250 220"/>
  </g>
  
  <!-- Pin through center -->
  <circle cx="150" cy="100" r="6" fill="#FFD700"/>
  <circle cx="250" cy="190" r="6" fill="#FFD700"/>
  
  <!-- Chain links attached -->
  <g stroke="#A0A0A0" stroke-width="6" fill="none">
    <line x1="150" y1="50" x2="150" y2="80"/>
    <line x1="250" y1="220" x2="250" y2="250"/>
  </g>
  
  <text x="200" y="280" font-family="Arial" font-size="12" fill="#004E89" text-anchor="middle" font-weight="bold">Shackle Connector 25mm</text>
</svg>
