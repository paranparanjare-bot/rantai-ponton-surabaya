<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <defs><linearGradient id="g5" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#87CEEB"/><stop offset="100%" style="stop-color:#0FA3B1"/></linearGradient></defs>
  <rect width="400" height="300" fill="url(#g5)"/>
  
  <!-- Platform smaller -->
  <rect x="80" y="180" width="240" height="60" fill="#8B7355" rx="4"/>
  <rect x="80" y="180" width="240" height="15" fill="#A0826D"/>
  
  <!-- Chains -->
  <g stroke="#FFD700" stroke-width="3" fill="none">
    <line x1="110" y1="180" x2="110" y2="110"/>
    <line x1="290" y1="180" x2="290" y2="110"/>
  </g>
  
  <!-- Excavator -->
  <g fill="#FF6B35">
    <rect x="140" y="160" width="120" height="45" rx="4"/>
    <circle cx="160" cy="205" r="10" fill="#333"/>
    <circle cx="250" cy="205" r="10" fill="#333"/>
  </g>
  
  <text x="200" y="280" font-family="Arial" font-size="14" fill="#004E89" text-anchor="middle" font-weight="bold">Ponton Excavator 7x10m</text>
</svg>
