<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <defs><linearGradient id="g9" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#CBD5E0"/><stop offset="100%" style="stop-color:#A0AEC0"/></linearGradient></defs>
  <rect width="400" height="300" fill="url(#g9)"/>
  
  <!-- Concrete anchor block -->
  <rect x="100" y="100" width="200" height="120" fill="#666" stroke="#333" stroke-width="3" rx="4"/>
  
  <!-- Top surface lighter -->
  <rect x="100" y="100" width="200" height="30" fill="#888" stroke="#333" stroke-width="2" rx="4"/>
  
  <!-- Mounting loops -->
  <g stroke="#FFD700" stroke-width="6" fill="none">
    <path d="M 140 100 A 15 15 0 0 1 140 80" stroke-linecap="round"/>
    <path d="M 260 100 A 15 15 0 0 1 260 80" stroke-linecap="round"/>
  </g>
  
  <!-- Weight text on block -->
  <text x="200" y="170" font-family="Arial" font-size="24" fill="#FFF" text-anchor="middle" font-weight="bold">1000kg</text>
  
  <text x="200" y="270" font-family="Arial" font-size="12" fill="#004E89" text-anchor="middle" font-weight="bold">Concrete Anchor 1000kg</text>
</svg>
