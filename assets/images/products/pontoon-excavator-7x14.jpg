<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <defs><linearGradient id="g4" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#87CEEB"/><stop offset="100%" style="stop-color:#0FA3B1"/></linearGradient></defs>
  <rect width="400" height="300" fill="url(#g4)"/>
  
  <!-- Platform -->
  <rect x="50" y="180" width="300" height="60" fill="#8B7355" rx="4"/>
  <rect x="50" y="180" width="300" height="15" fill="#A0826D"/>
  
  <!-- Chains -->
  <g stroke="#FFD700" stroke-width="3" fill="none">
    <line x1="80" y1="180" x2="80" y2="100"/>
    <line x1="320" y1="180" x2="320" y2="100"/>
    <circle cx="80" cy="120" r="8"/>
    <circle cx="320" cy="120" r="8"/>
  </g>
  
  <!-- Excavator outline -->
  <g fill="#FF6B35">
    <rect x="120" y="160" width="160" height="50" rx="4"/>
    <circle cx="150" cy="210" r="12" fill="#333"/>
    <circle cx="270" cy="210" r="12" fill="#333"/>
  </g>
  
  <text x="200" y="280" font-family="Arial" font-size="14" fill="#004E89" text-anchor="middle" font-weight="bold">Ponton Excavator 7x14m</text>
</svg>
